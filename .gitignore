# OpenClaw Backup - Keep only essential config and memories

# Dependencies and build artifacts
.env
.venv
env/
venv/
ENV/
VENV/
node_modules/
npm-debug.log
yarn-error.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS generated files
Thumbs.db
.DS_Store

# Logs
*.log

# Skill dependencies (keep only SKILL.md and scripts/)
skills/*/.venv/
skills/*/env/
skills/*/lib/
skills/*/.venv*
skills/*/node_modules/
skills/*/dist/
skills/*/build/
skills/*/*.egg-info/

# Browser data (should not be backed up)
skills/*/data/browser_state/

# Temporary files
tmp/
temp/
*.tmp

# Local configuration (may contain secrets)
config.local.json
secrets.json
credentials.json
*.pem
*.key

# Backup location (we're creating the backup itself)
openclaw-backup/

# Optional: Uncomment if you want to exclude memories from backup
# memory/

# Optional: Uncomment if you want to exclude skills from backup
# skills/