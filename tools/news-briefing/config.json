  "schedules": {
    "morning": {"label": "🌅 早间简报", "cron": "0 8 * * *", "desc": "每天早8点"},
    "noon": {"label": "☀️ 午间简报", "cron": "0 12 * * *", "desc": "每天中午12点"},
    "evening": {"label": "🌆 晚间简报", "cron": "0 18 * * *", "desc": "每天晚6点"},
    "breaking": {"label": "🚨 突发追踪", "cron": "0 */4 * * *", "desc": "每4小时"},
    "weekly": {"label": "📅 周报", "cron": "0 9 * * 1", "desc": "每周一早9点"}
