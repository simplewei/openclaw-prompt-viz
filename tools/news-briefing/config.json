{
  "version": "1.0.0",
  "description": "通用新闻简报生成器 - 支持多领域、多语言媒体源、定时推送",

  "domains": {
    "geopolitics": {
      "label": "🌍 地缘政治",
      "keywords": {
        "zh": ["国际关系", "外交", "战争", "冲突", "制裁", "峰会", "联合国"],
        "en": ["geopolitics", "diplomacy", "sanctions", "summit", "UN", "conflict"]
      }
    },
    "tech": {
      "label": "💻 科技",
      "keywords": {
        "zh": ["人工智能", "芯片", "半导体", "科技公司", "大模型", "量子计算"],
        "en": ["AI", "semiconductor", "chip", "tech company", "LLM", "quantum"]
      }
    },
    "economy": {
      "label": "📈 经济",
      "keywords": {
        "zh": ["经济", "股市", "汇率", "通胀", "利率", "贸易", "GDP"],
        "en": ["economy", "stock market", "inflation", "interest rate", "trade", "GDP"]
      }
    },
    "energy": {
      "label": "⚡ 能源",
      "keywords": {
        "zh": ["石油", "天然气", "新能源", "光伏", "风电", "核能", "能源转型"],
        "en": ["oil", "natural gas", "renewable energy", "solar", "nuclear", "energy transition"]
      }
    },
    "health": {
      "label": "🏥 健康医疗",
      "keywords": {
        "zh": ["医疗", "药物", "疫苗", "流行病", "生物科技", "临床试验"],
        "en": ["healthcare", "pharmaceutical", "vaccine", "pandemic", "biotech", "clinical trial"]
      }
    },
    "finance": {
      "label": "💰 金融",
      "keywords": {
        "zh": ["银行", "央行", "货币政策", "数字货币", "加密货币", "IPO"],
        "en": ["banking", "central bank", "monetary policy", "CBDC", "crypto", "IPO"]
      }
    },
    "climate": {
      "label": "🌿 气候环境",
      "keywords": {
        "zh": ["气候变化", "碳排放", "极端天气", "环保", "碳中和"],
        "en": ["climate change", "carbon emission", "extreme weather", "carbon neutral"]
      }
