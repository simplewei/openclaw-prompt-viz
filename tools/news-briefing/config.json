        {"name": "人民日报", "searchHint": "site:people.com.cn", "weight": 3},
        {"name": "央视新闻", "searchHint": "site:news.cctv.com", "weight": 3},
        {"name": "财新网", "searchHint": "site:caixin.com", "weight": 2},
